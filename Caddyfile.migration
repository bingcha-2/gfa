bcai.space {
    # Next.js admin session routes (login/logout via httpOnly console cookie)
    handle /api/session/* {
        reverse_proxy localhost:3000
    }

    # Next.js customer portal session routes (login/register/logout/forgot/reset).
    # These handlers set/clear the gfa.user.token httpOnly cookie and must NOT
    # be forwarded to the NestJS backend — they live in Next.js route handlers
    # under src/app/api/web-session/*.
    handle /api/web-session/* {
        reverse_proxy localhost:3000
    }

    # Next.js generic authenticated portal proxy.
    # Reads gfa.user.token cookie, forwards as Bearer to backend /web/*.
    # Must route through Next.js (not directly to :3001) so cookie→Bearer
    # conversion happens server-side. See src/app/api/web/[...path]/route.ts.
    handle /api/web/* {
        reverse_proxy localhost:3000
    }

    # NestJS API (all other /api/* go directly to backend)
    handle /api/* {
        reverse_proxy localhost:3001
    }

    # Legacy 兜底:/api 前缀化之前发布的老客户端会用不带 /api 的 /remote-*/* 路径
    # (remote-token / remote-codex / remote-anthropic)。新客户端已统一改打
    # /api/remote-*(见 bcai-wails 的 ANTHROPIC_REMOTE_BASE / CODEX_API_BASE / API_BASE)。
    # 这里把所有旧路径 rewrite 到 /api{uri},保证已发布的老客户端不落到 Next.js 404。
    @legacyRemote path /remote-token/* /remote-codex/* /remote-anthropic/*
    handle @legacyRemote {
        rewrite * /api{uri}
        reverse_proxy localhost:3001
    }

    # 客户端自动升级 + 下载（直接从文件夹 serve，无需 Next.js 重建）
    handle /updates/* {
        root * C:/Users/Administrator/Desktop/GFA/apps/web/public/updates
        uri strip_prefix /updates
        file_server
    }

    # Everything else → Next.js (pages, static assets)
    handle {
        reverse_proxy localhost:3000
    }
}

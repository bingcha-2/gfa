# ══════════════════════════════════════════════════════════════════════════════
# GFA Caddy config — split-domain deploy (admin console isolated on a subdomain)
#
# Two sites:
#   1) admin.bcai.space  → ADMIN surface only (proxied ONLY to Next.js :3000)
#   2) bcai.space        → customer surface (marketing + /account + client APIs)
#
# ── What the operator MUST configure before applying ──────────────────────────
#   • Hostnames ...... "admin.bcai.space" / "bcai.space" below are PLACEHOLDERS
#     — replace with the real domains. Additional customer-facing domains
#     (e.g. the bcai.lol fallback baked into deployed desktop clients) belong
#     on the MAIN site's address line, comma-separated — NEVER on the admin
#     site.
#   • DNS ............ A/AAAA record for the admin subdomain → this server.
#     Prefer a plain (non-CDN-proxied) record so the remote_ip allowlist hook
#     below sees real client IPs.
#   • TLS ............ Caddy auto-provisions certificates per site address via
#     ACME once DNS resolves and ports 80/443 are reachable. For an internal
#     CA or custom certs, add a `tls` directive inside the site block.
#   • Next.js env .... set ADMIN_HOST=admin.bcai.space (exactly the admin
#     hostname, no scheme/port) for the Next.js process and restart it. The
#     middleware (apps/web/src/middleware.ts) enforces the same split
#     host-side. Caddy and ADMIN_HOST must be switched over TOGETHER: this
#     file 404s the console on the main domain, so applying it while
#     ADMIN_HOST is still unset leaves the console reachable only via the
#     admin subdomain anyway — and setting ADMIN_HOST without this file
#     leaves Caddy serving console paths the middleware will 404. Do both,
#     then verify.
#   • IP allowlist ... enable the @blockedAdminIp hook below AND set
#     ADMIN_IP_ALLOWLIST for the Next.js process (the middleware check reads
#     X-Forwarded-For, so it keeps working even behind an extra proxy hop).
#   • Validate ....... run `caddy validate --config <this file>` (and
#     optionally `caddy adapt`) on the server BEFORE reloading — this file
#     was written offline and has not been run through caddy.
#
# Traffic map (who talks to which domain):
#   admins (browser)        → admin.bcai.space  /console, /login, /api/session/*,
#                                               admin /api/* (auth/rosetta/orders/
#                                               family-groups/… + /api/console/*)
#   customers (browser)     → bcai.space        /, marketing pages, /account/*,
#                                               /api/web/*, /api/web-session/*
#   desktop clients         → bcai.space (+ fallback domain)  /api/app/*,
#                                               legacy /remote-*, /updates/*
#   payment provider (epay) → bcai.space        /api/epay/*
# ══════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────────
# 1) ADMIN CONSOLE — isolated subdomain. PLACEHOLDER hostname, see header.
#
# Single upstream by design: ONLY Next.js (localhost:3000). Admin Bearer APIs
# (/api/auth, /api/console, /api/accounts, /api/rosetta, …) reach NestJS
# through Next's rewrites (apps/web/next.config.ts backendPrefixes), never
# directly from here — the NestJS port (:3001) is intentionally absent from
# this site block.
# ──────────────────────────────────────────────────────────────────────────────
admin.bcai.space {
	# The admin surface must never be indexed.
	header X-Robots-Tag "noindex, nofollow"

	# ── OPTIONAL: proxy-level IP allowlist (recommended) ──────────────────────
	# Uncomment and list operator IPs/CIDRs. Keep this handle FIRST: handles
	# with non-path matchers keep their source order, so it must appear before
	# @adminSurface to win. remote_ip matches the direct TCP peer — if a CDN
	# is ever put in front of this subdomain this stops being the client IP;
	# in that case rely on the middleware's ADMIN_IP_ALLOWLIST (reads
	# X-Forwarded-For) as the authoritative check. Set both in any case:
	# this hook and ADMIN_IP_ALLOWLIST are two layers of the same fence.
	#
	# @blockedAdminIp not remote_ip 203.0.113.10 198.51.100.0/24
	# handle @blockedAdminIp {
	#     respond 404
	# }

	# ── The ONLY paths that exist on this host ─────────────────────────────────
	#   /console, /console/*  console UI. If you configure a custom
	#                         ADMIN_PATH_PREFIX, add /<prefix> and /<prefix>/*
	#                         here (the middleware rewrites them to /console).
	#   /login, /login/*      root console login page
	#   /api/*                · /api/session/* — console cookie login/logout
	#                           (Next.js route handlers)
	#                         · admin Bearer APIs — proxied to NestJS by Next
	#                           rewrites, incl. the new /api/console/* namespace
	#                         MINUS the customer namespaces excluded below
	#   /_next/*, /favicon.ico, /bcai-icon.png
	#                         static assets the console UI needs
	#
	# Everything else (marketing pages, /account/*, /updates/*, customer APIs)
	# does not exist on this host → 404. The Next.js middleware enforces the
	# same rules host-side when ADMIN_HOST is set (defense in depth — either
	# layer alone already blocks).
	@adminSurface {
		path /console /console/* /login /login/* /api/* /_next/* /favicon.ico /bcai-icon.png
		not path /api/web /api/web/* /api/web-session /api/web-session/* /api/app /api/app/* /api/epay /api/epay/*
	}
	handle @adminSurface {
		reverse_proxy localhost:3000
	}

	# Anything not explicitly allowed above: pretend it does not exist.
	handle {
		respond 404
	}
}

# ──────────────────────────────────────────────────────────────────────────────
# 2) MAIN (customer) domain — marketing, /account portal, desktop-client and
#    payment APIs. PLACEHOLDER hostname, see header. Fallback customer domains
#    go on this address line, comma-separated:  bcai.space, bcai.lol {
# ──────────────────────────────────────────────────────────────────────────────
bcai.space {
	# ── Console surface REMOVED from the customer domain ──────────────────────
	# The admin console lives exclusively on the admin subdomain above.
	# (Path-matched handles sort longest-first, so these specific /api/…
	# handles reliably beat the /api/* catch-all further down.)
	#
	# Console cookie login/logout (Next route handlers) — gone from main.
	# (NOTE: /api/session may be renamed later — if the Next console session
	# routes move, update this handle and the admin-block comments in sync.)
	handle /api/session/* {
		respond 404
	}
	# Console-namespaced backend API (dual-mounted in NestJS) — admins use it
	# via the admin subdomain only. NOTE: legacy admin prefixes (/api/auth,
	# /api/accounts, /api/orders, …) remain reachable here for now — they are
	# Bearer-JWT protected in NestJS and some non-console traffic still shares
	# them; tighten by 404-ing them here once the console UI has fully moved
	# to /api/console/*.
	handle /api/console/* {
		respond 404
	}
	# Console pages + the root /login console page. The Next.js middleware
	# also 404s these when ADMIN_HOST is set; this is defense in depth.
	@consolePages path /console /console/* /login /login/*
	handle @consolePages {
		respond 404
	}

	# Next.js customer portal session routes (login/register/logout/forgot/reset).
	# These handlers set/clear the gfa.user.token httpOnly cookie and must NOT
	# be forwarded to the NestJS backend — they live in Next.js route handlers
	# under src/app/api/web-session/*.
	handle /api/web-session/* {
		reverse_proxy localhost:3000
	}

	# Next.js generic authenticated portal proxy.
	# Reads gfa.user.token cookie, forwards as Bearer to backend /web/*.
	# Must route through Next.js (not directly to :3001) so cookie→Bearer
	# conversion happens server-side. See src/app/api/web/[...path]/route.ts.
	handle /api/web/* {
		reverse_proxy localhost:3000
	}

	# NestJS API — every other /api/* path goes directly to the backend:
	# /api/app/* (desktop client login/heartbeat/lease — clients target THIS
	# host, never the admin subdomain), /api/epay/* (payment callbacks),
	# /api/public/*, /api/health, legacy /api/remote-*, …
	handle /api/* {
		reverse_proxy localhost:3001
	}

	# Legacy 兜底:/api 前缀化之前发布的老客户端会用不带 /api 的 /remote-*/* 路径
	# (remote-token / remote-codex / remote-anthropic)。新客户端已统一改打
	# /api/remote-*(见 bcai-wails 的 ANTHROPIC_REMOTE_BASE / CODEX_API_BASE / API_BASE)。
	# 这里把所有旧路径 rewrite 到 /api{uri},保证已发布的老客户端不落到 Next.js 404。
	@legacyRemote path /remote-token/* /remote-codex/* /remote-anthropic/*
	handle @legacyRemote {
		rewrite * /api{uri}
		reverse_proxy localhost:3001
	}

	# 客户端自动升级 + 下载(直接从文件夹 serve,无需 Next.js 重建)
	handle /updates/* {
		root * C:/Users/Administrator/Desktop/GFA/apps/web/public/updates
		uri strip_prefix /updates
		file_server
	}

	# Everything else → Next.js (marketing pages, /account portal, static
	# assets, and the legacy /app/* → /account/* 308 redirect shim).
	handle {
		reverse_proxy localhost:3000
	}
}

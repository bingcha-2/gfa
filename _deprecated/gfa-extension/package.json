{
  "name": "bcai-tools",
  "displayName": "冰茶AI",
  "description": "冰茶AI 智能编程助手 - 账号池管理与代理服务插件",
  "version": "4.0.39",
  "publisher": "bingcha",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/bingcha-2/gfa.git"
  },
  "activationEvents": [
    "*"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "bcai-server-sidebar",
          "title": "BCAI",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "bcai-server-sidebar": [
        {
          "type": "webview",
          "id": "bcai.serverView",
          "name": "BCAI"
        }
      ]
    },
    "configuration": {
      "title": "BCAI",
      "properties": {
        "bcai.apiBaseUrl": {
          "type": "string",
          "default": "https://bcai.site/api/proxy",
          "description": "GFA API 服务器地址 (例如 https://bcai.site/api/proxy)"
        },
        "bcai.rosettaApiBaseUrl": {
          "type": "string",
          "default": "https://bcai.site/api/rosetta",
          "description": "Rosetta/员工账号 API 地址"
        },
        "bcai.rosettaRepoPath": {
          "type": "string",
          "default": "",
          "description": "Antigravity Rosetta 项目根目录路径 (留空则自动检测)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.mjs --production && cd webview-ui && npm run build",
    "build:server": "node scripts/build-profile.mjs server build",
    "build:client": "node scripts/build-profile.mjs client build",
    "build:employee": "node scripts/build-profile.mjs employee build",
    "build:ext": "node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch",
    "dev:webview": "cd webview-ui && npm run dev",
    "package": "npx @vscode/vsce package --no-dependencies",
    "package:server": "node scripts/build-profile.mjs server package",
    "package:client": "node scripts/build-profile.mjs client package",
    "package:employee": "node scripts/build-profile.mjs employee package",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25.0",
    "javascript-obfuscator": "^5.4.1",
    "typescript": "^5.8.3"
  }
}

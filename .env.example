# =============================================================================
# Google Family Automation — 环境变量配置模板
# 使用方式：  Copy-Item .env.example .env
# =============================================================================

# ── 数据库 ────────────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── 服务端口 ──────────────────────────────────────────────────────────────────
API_PORT="3001"
WEB_PORT="3000"
WORKER_NAME="worker-1"
API_BASE_URL="http://127.0.0.1:3001/api"

# ── AdsPower ──────────────────────────────────────────────────────────────────
ADSPOWER_HOST="http://127.0.0.1:50325"
# ⚠️ 必填：在 AdsPower → 设置 → API Key 中获取
ADSPOWER_API_KEY=""

# Browser pool: comma-separated AdsPower profile IDs (manually created by ops)
ADSPOWER_POOL_IDS="profile-id-1,profile-id-2,profile-id-3"

# ── 安全配置 ──────────────────────────────────────────────────────────────────
# ⚠️ 必填（32位以上强随机字符串）。留空时，服务启动会直接失败。
# 生成：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="REPLACE_WITH_A_STRONG_RANDOM_SECRET_AT_LEAST_32_CHARS"

# CORS 允许的来源，逗号分隔。留空则拒绝所有跨域请求。
# 开发: http://localhost:3000
# 生产: https://your-admin-domain.com
CORS_ALLOWED_ORIGINS="http://localhost:3000"

# 管理后台 URL 前缀（不含 /）。留空则使用默认 console。
# 生产：改为随机字符串，如 manage-x7k2p，隐藏登录入口。
# 生成：node -e "console.log(require('crypto').randomBytes(5).toString('hex'))"
ADMIN_PATH_PREFIX="console"

# 允许访问管理后台的客户端 IP（逗号分隔，留空则不限）。
# 例如：127.0.0.1,192.168.1.0
ADMIN_IP_ALLOWLIST=""

# Session Cookie 是否强制 HTTPS（生产 HTTPS 部署时改为 true）
CONSOLE_COOKIE_SECURE=""

# 官网「进入用户中心」按钮的跳转目标。
# 单域部署：留空，使用相对路径 /account。
# 分域部署（官网 bcai.lol / 用户中心 my.bcai.lol）：官网域会 404 掉相对的
# /account，需指向用户中心子域绝对地址，如 https://my.bcai.lol/account
NEXT_PUBLIC_ACCOUNT_URL=""

# ── 邮件 SMTP（找回密码 / 邮箱验证）──────────────────────────────────────────
# 代码已内置线上默认（QQ 邮箱，见 apps/server/src/shared/mail/mail.service.ts 的
# FALLBACK_SMTP）。下面这些变量【不设/保持注释】即用内置默认发信；要改用别的邮箱，
# 取消注释并填值，按字段覆盖。⚠️ 改完必须重启 server 才生效（transporter 有缓存）。
#
# 关闭发信：把 SMTP_HOST 显式设为空串（SMTP_HOST=""）即该环境 no-op。
# 测试环境（NODE_ENV=test）自动不发信。
#
# 换别的个人邮箱时用「授权码」（不是登录密码）：
#   QQ 邮箱   smtp.qq.com    465(SSL)/587   设置→账号→开启 POP3/SMTP→生成授权码
#   163 邮箱  smtp.163.com   465(SSL)/994   设置→POP3/SMTP/IMAP→开启→授权码
#   Gmail     smtp.gmail.com 465(SSL)/587   开两步验证后生成「应用专用密码」
# ⚠️ 用个人邮箱时，MAIL_FROM 的地址（<>内）必须等于 SMTP_USER，否则会被服务商拒收。
# SMTP_HOST="smtp.qq.com"
# SMTP_PORT="465"
# SMTP_SECURE="true"          # 465 端口 true(SSL)；587 端口 false(STARTTLS)
# SMTP_USER="you@qq.com"
# SMTP_PASS="授权码"
# MAIL_FROM="bcai.lol <you@qq.com>"

# 邮件正文里链接（重置密码 / 验证邮箱）使用的前端域名前缀，不含末尾 /
# 注：支付完成后的「同步跳转」默认也用它（${WEB_BASE_URL}/account/billing）。
WEB_BASE_URL="https://bcai.lol"

# ── 支付：彩虹易支付 epay（支付宝 / 微信扫码）─────────────────────────────────
# 真实值放进 .env（不提交），这里只留占位符。⚠️ 切勿把真实 EPAY_KEY 写进本模板。
# 留空 EPAY_PID 或 EPAY_KEY → 支付整体关闭（回调一律 fail-closed 拒绝，安全默认）。
EPAY_PID=""                       # 商户 ID（zhunfu「API信息」页）
EPAY_KEY=""                       # 商户密钥（MD5 签名用，切勿泄露 / 提交）
EPAY_API_BASE=""                  # 网关地址，不含末尾 /，如 https://vip1.zhunfu.cn
# 回调（epay→后端，公网可达）与跳转（浏览器）地址。分域名部署示例：
#   EPAY_NOTIFY_URL="https://api.bcai.lol/api/epay/notify"
#   EPAY_RETURN_URL="https://my.bcai.lol/account/billing"
# 本地调试：NOTIFY 用内网穿透公网地址（ngrok），RETURN 用 http://localhost:3000/account/billing
EPAY_NOTIFY_URL=""
EPAY_RETURN_URL=""

# 支付通道手续费率（%）。>0 时在套餐价上加价，由用户承担（实付=基准价+手续费，向上取整到分）。留空/0=不加价。
# 线上当前用 3.6（彩虹易支付实际通道费率）；模板默认 0 不加价，按需覆盖。
EPAY_FEE_PERCENT="0"

# 邀请返佣比例（0-100 整数）。被邀请人付款后邀请人按此比例得余额。留空默认 10。
EPAY_REFERRAL_PERCENT="10"

{
  "name": "@gfa/worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --fileParallelism=false",
    "test:unit": "vitest run src/__tests__/*.unit.spec.ts --fileParallelism=false",
    "test:integration": "vitest run src/__tests__/*.integration.spec.ts --fileParallelism=false",
    "test:e2e": "vitest run src/__tests__/*.e2e.spec.ts --fileParallelism=false",
    "test:smoke": "vitest run --config vitest.smoke.config.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@gfa/shared": "workspace:*",
    "@prisma/client": "^6.6.0",
    "bullmq": "^5.48.1",
    "dotenv": "^16.4.7",
    "ioredis": "^5.6.1",
    "otpauth": "^9.5.0",
    "playwright": "^1.60.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@vitest/coverage-v8": "^4.1.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.1"
  }
}

</script>



    <script>
        /*global anonEv */

        try {
            window._luckyPrompts = function (_root) {
                var root = _root || document;
                var bar = root.querySelector('[data-banner-name]');
                var textarea = root.querySelector('#textarea-input');
                var luckyBtn = root.querySelector('#gai-lucky-btn');
                var eventName = bar?.getAttribute('data-event-name');
                var bannerName = bar?.getAttribute('data-banner-name');
                if (!luckyBtn || !textarea) {
                    return;
                }
                var sd_variant =  root.querySelector('body')?.classList.contains('v-sd');
                var tbs_variant = root.querySelector('body')?.classList.contains('v-tbs');
                var source = 'sf';
                if (sd_variant) {
                    source = 'sd';
                } else if (tbs_variant) {
                    source = 'tbs';
                }
                var luckyPrompts = [
                    'Build a simple to-do app with add, edit, complete, and delete tasks',
                    'Create a basic budget app to log income and expenses, categorize',
                    'Build a habit tracker where users check off daily habits and see',
                    'Create a minimal notes app with create, edit, search, and delete',
                    'Build a weather app that shows current conditions and a 5-day'
                ];

                function shuffleInPlace(arr) {
                    for (let i = arr.length - 1; i > 0; i--) {
                        const j = Math.floor(Math.random() * (i + 1));
                        [arr[i], arr[j]] = [arr[j], arr[i]];
                    }
                    return arr;
                }

                function makeShuffleBag(items) {
                    let bag = [];
                    return function next() {
                        if (bag.length === 0) {
                            bag = items.slice();        // fresh copy
                            shuffleInPlace(bag);        // random order
                        }
                        return bag.pop();             // pop is O(1)
                    };
                }

                var nextLuckyPrompt = makeShuffleBag(luckyPrompts);
                var evOpts = {
                    client: bannerName,
                    source: window.banner_options?.source || source,
                };
                luckyBtn.addEventListener('click', function (e) {
                    e.preventDefault();
                    e.stopPropagation();
                    var pick = nextLuckyPrompt();
                    window.open(
                        'https://aistudio.google.com/apps?prompt=' + encodeURIComponent(pick),
                        '_blank'
                    );
                    textarea.value = pick;
                    textarea.dispatchEvent(new Event('mousedown', {bubbles: true}));
                    textarea.dispatchEvent(new Event('input', {bubbles: true}));
                    anonEv(evOpts, ['trackEvent', eventName, 'cta-lucky']);
                });
            };
            (function () {
                const font = new FontFace(
                      'Google Sans',
                      'url(//a.fsdn.com/con/css/fonts/sftheme/google-sans-v67-latin-regular.woff2'
                    );
                font.load().then(loaded => {
                  document.fonts.add(loaded);
                });
                window._luckyPrompts(null);
            })();
    }catch(e){}
    </script>



  

    

            
    

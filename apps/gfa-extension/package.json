{
  "name": "bcai-tools",
  "displayName": "冰茶AI",
  "description": "冰茶 AI 续航终端 — Google One 家庭自动化操作面板",
  "version": "3.4.31",
  "publisher": "bingcha",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/bingcha135-sys/GFA-per.git"
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "bcai-sidebar",
          "title": "BCAI",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "bcai-sidebar": [
        {
          "type": "webview",
          "id": "bcai.welcomeView",
          "name": "BCAI"
        }
      ]
    },
    "configuration": {
      "title": "BCAI",
      "properties": {
        "bcai.apiBaseUrl": {
          "type": "string",
          "default": "https://bcai.site/api/proxy",
          "description": "GFA API 服务器地址 (例如 https://bcai.site/api/proxy)"
        },
        "bcai.rosettaRepoPath": {
          "type": "string",
          "default": "",
          "description": "Antigravity Rosetta 项目根目录路径 (留空则自动检测)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.mjs --production && cd webview-ui && npm run build",
    "build:ext": "node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch",
    "dev:webview": "cd webview-ui && npm run dev",
    "package": "npx @vscode/vsce package --no-dependencies",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25.0",
    "javascript-obfuscator": "^5.4.1",
    "typescript": "^5.8.3"
  }
}

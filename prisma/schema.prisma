generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OPERATIONS
  SUPPORT
}

enum AccountStatus {
  HEALTHY
  LOGIN_REQUIRED
  VERIFICATION_REQUIRED
  RISKY
  DISABLED
}

enum GroupStatus {
  ACTIVE
  MANUAL_ONLY
  DISABLED
}

enum MemberStatus {
  ACTIVE
  REMOVED
  PENDING
}

enum InviteStatus {
  SENT
  ACCEPTED
  EXPIRED
  FAILED
}

enum RedeemCodeStatus {
  UNUSED
  RESERVED
  USED
  DISABLED
  EXPIRED
}

enum RedeemCodeType {
  JOIN_GROUP    // Standard: customer joins a family group
  ACCOUNT_SWAP  // Customer self-service account replacement (one-time)
  SUBSCRIPTION  // Long-term: allows periodic account swaps within validity
}

enum OrderType {
  JOIN          // 上车（JOIN_GROUP 码）
  SWAP          // 一次性换号（ACCOUNT_SWAP 码）
  SUBSCRIPTION  // 订阅换号（SUBSCRIPTION 码）
}

enum SwapRecordStatus {
  PENDING
  COMPLETED
  FAILED
}

enum OrderStatus {
  CREATED
  CODE_VERIFIED
  GROUP_ASSIGNED
  TASK_QUEUED
  TASK_RUNNING
  INVITE_SENT
  WAIT_USER_ACCEPT
  MANUAL_REVIEW
  FAILED
  COMPLETED
  EXPIRED
}

enum TaskStatus {
  PENDING
  RUNNING
  SUCCESS
  INVITE_SENT
  REPLACED_AND_INVITE_SENT
  FAILED_RETRYABLE
  FAILED_FINAL
  MANUAL_REVIEW
  CANCELLED
}

enum TaskType {
  INVITE_MEMBER
  REMOVE_MEMBER
  REPLACE_MEMBER
  SYNC_FAMILY_GROUP
  HEALTH_CHECK_ACCOUNT
  OAUTH_AUTHORIZE
  ACCEPT_INVITE
  TEST_LOGIN
  PHONE_VERIFY
}

enum TransferPhase {
  REMOVING
  INVITING
  COMPLETED
  PARTIALLY_FAILED
  FAILED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  displayName  String
  role         UserRole
  permissions  String?    // JSON array: ["accounts","groups","orders","tasks","codes","expire","scheduler","lookup"]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]
}

model Account {
  id                  String        @id @default(cuid())
  name                String
  loginEmail          String        @unique
  loginPassword       String?
  totpSecret          String?
  recoveryEmail       String?
  appPassword         String?
  adspowerProfileId   String        @unique
  status              AccountStatus @default(HEALTHY)
  syncError           String?
  riskScore           Int           @default(0)
  dailyOperationCount Int           @default(0)
  dailyOperationLimit Int           @default(20)
  lastOperationDate   String?
  notes               String?
  lastLoginAt              DateTime?
  lastHealthCheckAt        DateTime?
  subscriptionExpiresAt    DateTime?
  subscriptionStatus       String?   // "ACTIVE" | "EXPIRED" | "SUSPENDED"
  subscriptionStatusUpdatedAt DateTime? // timestamp when subscriptionStatus last changed
  subscriptionPlan         String?   // e.g. "Google AI Ultra 30 TB"
  lastAutoMaintenanceAt    DateTime?
  refreshToken             String?       // OAuth refresh_token (extracted via phone-verify)
  tokenObtainedAt          DateTime?     // when the token was obtained
  tokenStatus              String?       // "unused" | "used"
  familyGroups             FamilyGroup[]
  tasks               Task[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model FamilyGroup {
  id                 String         @id @default(cuid())
  accountId          String
  groupName          String
  maxMembers         Int            @default(6)
  memberCount        Int            @default(0)
  availableSlots     Int            @default(0)
  pendingInviteCount Int            @default(0)
  yearlyChangeCount  Int            @default(0)
  yearlyChangeLimit  Int            @default(6)
  status             GroupStatus    @default(ACTIVE)
  riskScore          Int            @default(0)
  lastSyncedAt       DateTime?
  account            Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  members            FamilyMember[]
  invites            FamilyInvite[]
  orders             Order[]
  tasks              Task[]
  transfersAsSource  TransferBatch[] @relation("TransferSource")
  transfersAsTarget  TransferBatch[] @relation("TransferTarget")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model FamilyMember {
  id              String       @id @default(cuid())
  familyGroupId   String
  email           String
  displayName     String?
  role            String
  status          MemberStatus @default(ACTIVE)
  googleMemberId  String?      // GAIA member ID from href="/family/member/g/{id}"
  canAutoRemove   Boolean      @default(false)
  expiresAt       DateTime?    // member-level expiry; null = never expires
  joinedAt        DateTime?
  removedAt       DateTime?
  familyGroup     FamilyGroup  @relation(fields: [familyGroupId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([familyGroupId, email])
}

model FamilyInvite {
  id            String       @id @default(cuid())
  familyGroupId String
  email         String
  status        InviteStatus @default(SENT)
  sentAt        DateTime     @default(now())
  respondedAt   DateTime?
  expiresAt     DateTime?
  familyGroup   FamilyGroup  @relation(fields: [familyGroupId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([familyGroupId, email])
}

model RedeemCode {
  id              String           @id @default(cuid())
  code            String           @unique
  product         String           @default("GOOGLE_ONE")
  codeType        RedeemCodeType   @default(JOIN_GROUP)
  usesAllowed     Int              @default(1)
  status          RedeemCodeStatus @default(UNUSED)
  expiresAt       DateTime?
  usedAt          DateTime?
  validDays       Int?             // SUBSCRIPTION: validity period in days (set at generation)
  swapLimit       Int              @default(0)  // Max swaps allowed within each window (0 = unlimited)
  swapWindowHours Int              @default(5)  // Rolling window for swap rate-limit (hours)
  order           Order?
  createdById     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status])
  @@index([codeType])
}

model Order {
  id            String       @id @default(cuid())
  orderNo       String       @unique
  orderType     OrderType    @default(JOIN)
  redeemCodeId  String?      @unique
  userEmail     String
  familyGroupId String?
  status        OrderStatus  @default(CREATED)
  resultMessage String?
  assignedAt    DateTime?
  expiresAt     DateTime?  // membership expiry (set at redeem time)
  expiredAt     DateTime?  // actual auto-removal timestamp (audit)
  swapCount     Int          @default(0)  // number of swaps performed
  lastSwapAt    DateTime?                 // timestamp of most recent swap
  redeemCode    RedeemCode?  @relation(fields: [redeemCodeId], references: [id], onDelete: SetNull)
  familyGroup   FamilyGroup? @relation(fields: [familyGroupId], references: [id], onDelete: SetNull)
  tasks         Task[]
  swapRecords   SwapRecord[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([userEmail])
  @@index([status])
  @@index([createdAt])
}

model Task {
  id                   String          @id @default(cuid())
  type                 TaskType
  orderId              String?
  familyGroupId        String?
  accountId            String?
  workerId             String?
  transferBatchId      String?
  source               String          @default("manual")
  status               TaskStatus      @default(PENDING)
  priority             Int             @default(0)
  retryCount           Int             @default(0)
  maxRetryCount        Int             @default(3)
  payload              String          @default("{}")
  lastErrorCode        String?
  lastErrorMessage     String?
  beforeScreenshotPath String?
  afterScreenshotPath  String?
  errorScreenshotPath  String?
  startedAt            DateTime?
  finishedAt           DateTime?
  order                Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  familyGroup          FamilyGroup?    @relation(fields: [familyGroupId], references: [id], onDelete: SetNull)
  account              Account?        @relation(fields: [accountId], references: [id], onDelete: SetNull)
  transferBatch        TransferBatch?  @relation(fields: [transferBatchId], references: [id], onDelete: SetNull)
  logs                 TaskLog[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([accountId, status])
  @@index([source, status])
  @@index([familyGroupId])
}

model TaskLog {
  id        String   @id @default(cuid())
  taskId    String
  level     String
  message   String
  extra     String?
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  operatorId String?
  action     String
  targetType String
  targetId   String
  detail     String?
  operator   User?    @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
}

model TransferBatch {
  id                String         @id @default(cuid())
  sourceGroupId     String
  targetGroupId     String
  phase             TransferPhase  @default(REMOVING)
  memberEmails      String         // JSON array of emails
  totalMembers      Int
  removedCount      Int            @default(0)
  removeFailedCount Int            @default(0)
  invitedCount      Int            @default(0)
  inviteFailedCount Int            @default(0)
  errorDetail       String?        // JSON array: [{email, error}]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  sourceGroup       FamilyGroup    @relation("TransferSource", fields: [sourceGroupId], references: [id])
  targetGroup       FamilyGroup    @relation("TransferTarget", fields: [targetGroupId], references: [id])
  tasks             Task[]
}

model SwapRecord {
  id        String           @id @default(cuid())
  orderId   String
  oldEmail  String
  newEmail  String
  taskId    String?
  status    SwapRecordStatus @default(PENDING)
  order     Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([orderId])
}

model SystemSchedulerConfig {
  id                          String   @id @default("default")
  enabled                     Boolean  @default(false)
  maxAccountsPerRun           Int      @default(10)
  accountCooldownMinutes      Int      @default(60)
  runWindowStart              String   @default("22:00")
  runWindowEnd                String   @default("08:00")
  staleSyncThresholdMinutes   Int      @default(1440)
  syncEnabled                 Boolean  @default(true)
  removeExpiredMembersEnabled Boolean  @default(true)
  cancelTimedOutInvitesEnabled Boolean @default(true)
  deduplicateMembersEnabled   Boolean  @default(true)
  inviteTimeoutDays           Int      @default(3)
  lastRunAt                   DateTime?
  lastRunStatus               String?
  lastRunSummary              String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

/// Phone number pool for automated Google phone verification.
/// Phones are uploaded from GFA Clients (single direction: client → server).
model PhonePool {
  id             String    @id @default(cuid())
  phoneNumber    String    @unique
  countryCode    String    @default("+1")
  smsUrl         String
  status         String    @default("available") // available / used / in_use / disabled
  usedCount      Int       @default(0)
  failureCount   Int       @default(0)
  lastUsedAt     DateTime?
  lastCode       String?
  disabledReason String?
  source         String?   // client identifier
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
}

/// Lifecycle status for agent-managed child accounts.
enum AgentAccountStatus {
  REGISTERED       // 已录入凭证
  PHONE_VERIFIED   // 已过手机验证（有refresh_token）
  IN_GROUP         // 已进组
  UPLOADED         // 已上号到CLIProxy
  REMOVED          // 已从号池删除
}

/// Child accounts managed through the Agent Service panel.
/// Separate from Account (母号). Tracks the full lifecycle:
///   REGISTERED → PHONE_VERIFIED → IN_GROUP → UPLOADED → REMOVED
model AgentAccount {
  id              String              @id @default(cuid())
  loginEmail      String              @unique
  loginPassword   String
  totpSecret      String?
  recoveryEmail   String?
  status          AgentAccountStatus  @default(REGISTERED)
  refreshToken    String?             // OAuth refresh_token (auto-captured)
  tokenObtainedAt DateTime?           // when refresh_token was last obtained
  familyGroupId   String?             // which family group this account joined
  uploadedAt      DateTime?           // when uploaded to CLIProxy
  removedAt       DateTime?           // when removed from CLIProxy
  lastTaskId      String?             // most recent automation task ID
  notes           String?
  pool            String              @default("pending")  // "pending" | "no_ban" | "ban_risk"
  banned          Boolean             @default(false)       // 已封/未封
  uploadedToPool  DateTime?           // 上号时间（移入已上号池的时间）
  motherAccountId String?             // 关联母号 Account ID
  motherGroupId   String?             // 关联家庭组 FamilyGroup ID
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([status])
  @@index([loginEmail])
  @@index([pool])
  @@index([pool, banned])
}

/// FAQ items editable from the admin console, displayed on /faq public page.
model FaqItem {
  id        String   @id @default(cuid())
  category  String                  // Category label, e.g. "加入家庭组", "反重力使用"
  question  String                  // Question title
  answer    String                  // Answer content (rich HTML)
  sortOrder Int      @default(0)    // Display order (lower = first)
  published Boolean  @default(true) // Whether visible on public page
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, sortOrder])
}

model SiteSetting {
  key       String   @id               // e.g. "contact_wechat", "contact_qrcode_url"
  value     String                     // Value (text, URL, etc.)
  updatedAt DateTime @updatedAt
}

/// Per-event token usage: recorded in reportResult() for each billed usage report.
/// One row per successful (deduped, exactly-once) report from a card (access key).
model CardTokenUsage {
  id                String   @id @default(cuid())
  accessKeyId       String                     // Card (access key) ID that consumed the tokens
  accessKeyName     String?                    // Card display name (snapshot at record time)
  accountId         Int?                       // Rosetta account that served the request
  modelKey          String                     // Model identifier (e.g. gemini-..., gpt-..., claude-...)
  bucket            String                     // Billing bucket: gemini / codex / opus
  status            Int      @default(0)        // Reported HTTP status
  inputTokens       Int      @default(0)
  outputTokens      Int      @default(0)
  cachedInputTokens Int      @default(0)
  rawTotalTokens    Int      @default(0)        // Raw total before cache discount
  totalTokens       Int      @default(0)        // Billable total (after cache discount)
  timestamp         DateTime @default(now())

  @@index([timestamp])
  @@index([accessKeyId, timestamp])
  @@index([accessKeyId, modelKey])
  @@index([accountId, timestamp])
}

/// 账号 5h/周额度水位时序:on-change 去重后由 AccountQuotaSnapshotTracker 批量写入。
/// 三家(antigravity/codex/anthropic)统一处理:读账号 modelQuotaFractions,每个 key 记一笔。
/// modelKey = 该账号 fractions 的 key(codex→"codex" / anthropic→"claude" / antigravity→真实模型名),
/// 始终有值。codex/anthropic 一个 key 带 5h+周;antigravity 每模型一行(无周窗口)。
model AccountQuotaSnapshot {
  id            String   @id @default(cuid())
  provider      String                     // antigravity | codex | anthropic
  accountId     Int
  email         String?
  modelKey      String                     // 账号 modelQuotaFractions 的 key(三家统一)
  hourlyPercent Float?                     // 5h 剩余 %(0-100)
  weeklyPercent Float?                     // 周剩余 %(antigravity 无周窗口 → null)
  hourlyResetAt DateTime?
  weeklyResetAt DateTime?
  timestamp     DateTime @default(now())

  @@index([provider, accountId, timestamp])
  @@index([timestamp])
}

/// 学习出的 5h/周预算(从 quota-profiles.json 迁入)。一行一个 provider+planType+family。
/// 由 QuotaProfileTracker 内存聚合 + 定时批量 upsert。history* 存 JSON 数组(最近 20 个样本)。
model QuotaProfile {
  provider      String
  planType      String
  family        String                     // gemini | claude | gpt
  window5h      Float    @default(0)        // 学习的 5h 加权 token 预算(0=未知)
  weekly        Float    @default(0)        // 学习的周预算
  samples5h     Int      @default(0)
  samplesWeekly Int      @default(0)
  history5h     String   @default("[]")     // JSON: number[] 最近 5h 样本
  historyWeekly String   @default("[]")     // JSON: number[] 最近周样本
  lastUpdatedAt BigInt   @default(0)        // epoch ms

  @@id([provider, planType, family])
}

/// 拼车每卡 5h 已用量(决定"剩余"),跨重启持久化。FairShareTracker 内存聚合 + 定时批量 upsert。
/// 恢复后按 windowStart 判过期(跨 5h 边界丢弃)。
model FairShareWindow {
  provider        String
  accountId       Int
  bucket          String                   // 复合桶 product-family
  cardId          String
  windowStart     BigInt                   // epoch ms,5h 窗口起点
  weightedUsed    Float    @default(0)      // 本窗口该卡已用加权 token
  estimatedBudget Float    @default(0)
  confidence      String   @default("default")
  lastFraction    Float    @default(1)
  updatedAt       DateTime @default(now())

  @@id([provider, accountId, bucket, cardId])
  @@index([provider, accountId, bucket])
}

// ─── Customer Account System ────────────────────────────────────────────────

enum CustomerStatus {
  ACTIVE
  DISABLED
}

enum CustomerEmailTokenPurpose {
  VERIFY_EMAIL
  RESET_PASSWORD
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PlanOrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  EXPIRED
}

enum PayChannel {
  ALIPAY
  WXPAY
}

enum DeviceStatus {
  ACTIVE
  REVOKED
}

enum NotificationType {
  SYSTEM
  BILLING
  TICKET
  REFERRAL
  MIGRATION
}

enum TicketStatus {
  OPEN
  ANSWERED
  CLOSED
}

enum ReferralRewardStatus {
  PENDING
  GRANTED
  REVOKED
}

/// Terminal customer — fully separate from admin User.
model Customer {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  status        CustomerStatus @default(ACTIVE)
  emailVerified Boolean        @default(false)
  displayName   String?
  tokenVersion  Int            @default(0)   // bumped on password change/reset → revokes all JWTs
  referralCode  String         @unique
  invitedById   String?
  creditCents   Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  invitedBy     Customer?              @relation("CustomerReferrals", fields: [invitedById], references: [id])
  referrals     Customer[]             @relation("CustomerReferrals")
  emailTokens   CustomerEmailToken[]
  subscriptions Subscription[]
  planOrders    PlanOrder[]
  devices       Device[]
  notifications Notification[]
  tickets       Ticket[]

  @@index([invitedById])
}

/// Single-use email tokens for verification and password reset.
model CustomerEmailToken {
  id         String                    @id @default(cuid())
  customerId String
  tokenHash  String                    @unique
  purpose    CustomerEmailTokenPurpose
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime                  @default(now())

  customer   Customer                  @relation(fields: [customerId], references: [id])

  @@index([customerId])
}

/// Purchasable plan template.
model Plan {
  id                   String   @id @default(cuid())
  name                 String
  description          String?
  priceCents           Int
  durationDays         Int
  productEntitlements  String                    // JSON array e.g. ["antigravity","codex","anthropic"]
  bucketLimits         String?                   // JSON per-model caps
  levels               String?                   // JSON per-product plan levels
  weight               Int      @default(1)      // fair-share: 1=拼车 … 8=独享
  deviceLimit          Int      @default(1)
  weeklyTokenLimit     Int?                      // token count; 2^31 ceiling acceptable
  windowMs             Int      @default(18000000) // 5h in ms
  active               Boolean  @default(true)
  sortOrder            Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  planOrders  PlanOrder[]
  subscriptions Subscription[]
}

/// Active / past subscription; its id doubles as shadow access-key record id and fair-share cardId.
/// For migrated cards the id is set to the old card's id on create.
model Subscription {
  id                  String             @id @default(cuid())
  customerId          String
  planId              String?
  status              SubscriptionStatus @default(ACTIVE)
  startsAt            DateTime           @default(now())
  expiresAt           DateTime?          // nullable: migrated never-used card has no expiry until first use
  activatedFromOrderId String?           // PlanOrder.id that created/last extended this sub — exact order→sub link for reconcile + refund
  // Purchase-time snapshots decoupled from Plan
  productEntitlements String
  bucketLimits        String?
  bindings            String?            // JSON product→accountId mirror
  levels              String?
  weight              Int                @default(1)
  deviceLimit         Int                @default(1)
  weeklyTokenLimit    Int?
  windowMs            Int                @default(18000000)
  backingKeyValue     String             @unique  // opaque key value written into access-keys.json
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  customer  Customer  @relation(fields: [customerId], references: [id])
  plan      Plan?     @relation(fields: [planId], references: [id])

  @@index([customerId])
  @@index([planId])
  @@index([activatedFromOrderId])
}

/// Plan purchase order (distinct from the existing family-group Order).
model PlanOrder {
  id             String         @id @default(cuid())
  customerId     String
  planId         String
  subscriptionId String?        // filled on activation
  amountCents    Int
  payChannel     PayChannel
  outTradeNo     String         @unique  // idempotency anchor
  epayTradeNo    String?
  status         PlanOrderStatus @default(PENDING)
  notifyRaw      String?
  paidAt         DateTime?
  referrerId     String?        // Customer id of inviter at purchase time
  expiresAt      DateTime       // pending-payment TTL
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  customer  Customer  @relation(fields: [customerId], references: [id])
  plan      Plan      @relation(fields: [planId], references: [id])

  @@index([customerId])
  @@index([planId])
  @@index([status])
}

/// Customer device (supports multi-device enforcement and session revocation).
model Device {
  id          String       @id @default(cuid())
  customerId  String
  deviceId    String       // client-generated stable id
  name        String?
  platform    String?
  status      DeviceStatus @default(ACTIVE)
  lastSeenAt  DateTime?
  lastIp      String?
  sessionJti  String?      // current session token id; mismatch = revoked
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  customer    Customer     @relation(fields: [customerId], references: [id])

  @@unique([customerId, deviceId])
  @@index([customerId])
}

/// In-app notification for a customer.
model Notification {
  id         String           @id @default(cuid())
  customerId String
  type       NotificationType @default(SYSTEM)
  title      String
  body       String?
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  customer   Customer         @relation(fields: [customerId], references: [id])

  @@index([customerId, createdAt])
}

/// Support ticket opened by a customer.
model Ticket {
  id         String       @id @default(cuid())
  customerId String
  subject    String
  status     TicketStatus @default(OPEN)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  customer   Customer       @relation(fields: [customerId], references: [id])
  messages   TicketMessage[]

  @@index([customerId])
}

/// Individual message within a support ticket.
model TicketMessage {
  id         String   @id @default(cuid())
  ticketId   String
  authorType String   // "CUSTOMER" | "ADMIN"
  authorId   String?
  body       String
  createdAt  DateTime @default(now())

  ticket     Ticket   @relation(fields: [ticketId], references: [id])

  @@index([ticketId])
}

/// Referral reward record — one per qualifying order, replay-safe.
model ReferralReward {
  id           String               @id @default(cuid())
  referrerId   String               // Customer id being rewarded
  inviteeId    String
  planOrderId  String               @unique  // one reward per order
  amountCents  Int
  status       ReferralRewardStatus @default(GRANTED)
  createdAt    DateTime             @default(now())

  @@index([referrerId])
}

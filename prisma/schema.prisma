generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OPERATIONS
  SUPPORT
}

enum AccountStatus {
  HEALTHY
  LOGIN_REQUIRED
  VERIFICATION_REQUIRED
  RISKY
  DISABLED
}

enum GroupStatus {
  ACTIVE
  MANUAL_ONLY
  DISABLED
}

enum MemberStatus {
  ACTIVE
  REMOVED
  PENDING
}

enum InviteStatus {
  SENT
  ACCEPTED
  EXPIRED
  FAILED
}

enum RedeemCodeStatus {
  UNUSED
  RESERVED
  USED
  DISABLED
  EXPIRED
}

enum RedeemCodeType {
  JOIN_GROUP    // Standard: customer joins a family group
  ACCOUNT_SWAP  // Customer self-service account replacement (one-time)
  SUBSCRIPTION  // Long-term: allows periodic account swaps within validity
}

enum OrderType {
  JOIN          // 上车（JOIN_GROUP 码）
  SWAP          // 一次性换号（ACCOUNT_SWAP 码）
  SUBSCRIPTION  // 订阅换号（SUBSCRIPTION 码）
}

enum SwapRecordStatus {
  PENDING
  COMPLETED
  FAILED
}

enum OrderStatus {
  CREATED
  CODE_VERIFIED
  GROUP_ASSIGNED
  TASK_QUEUED
  TASK_RUNNING
  INVITE_SENT
  WAIT_USER_ACCEPT
  MANUAL_REVIEW
  FAILED
  COMPLETED
  EXPIRED
}

enum TaskStatus {
  PENDING
  RUNNING
  SUCCESS
  INVITE_SENT
  REPLACED_AND_INVITE_SENT
  FAILED_RETRYABLE
  FAILED_FINAL
  MANUAL_REVIEW
  CANCELLED
}

enum TaskType {
  INVITE_MEMBER
  REMOVE_MEMBER
  REPLACE_MEMBER
  SYNC_FAMILY_GROUP
  HEALTH_CHECK_ACCOUNT
  OAUTH_AUTHORIZE
  ACCEPT_INVITE
  TEST_LOGIN
  PHONE_VERIFY
}

enum TransferPhase {
  REMOVING
  INVITING
  COMPLETED
  PARTIALLY_FAILED
  FAILED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  displayName  String
  role         UserRole
  permissions  String?    // JSON array: ["accounts","groups","orders","tasks","codes","expire","scheduler","lookup"]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]
}

model Account {
  id                  String        @id @default(cuid())
  name                String
  loginEmail          String        @unique
  loginPassword       String?
  totpSecret          String?
  recoveryEmail       String?
  appPassword         String?
  adspowerProfileId   String        @unique
  status              AccountStatus @default(HEALTHY)
  syncError           String?
  riskScore           Int           @default(0)
  dailyOperationCount Int           @default(0)
  dailyOperationLimit Int           @default(20)
  lastOperationDate   String?
  notes               String?
  lastLoginAt              DateTime?
  lastHealthCheckAt        DateTime?
  subscriptionExpiresAt    DateTime?
  subscriptionStatus       String?   // "ACTIVE" | "EXPIRED" | "SUSPENDED"
  subscriptionStatusUpdatedAt DateTime? // timestamp when subscriptionStatus last changed
  subscriptionPlan         String?   // e.g. "Google AI Ultra 30 TB"
  lastAutoMaintenanceAt    DateTime?
  refreshToken             String?       // OAuth refresh_token (extracted via phone-verify)
  tokenObtainedAt          DateTime?     // when the token was obtained
  tokenStatus              String?       // "unused" | "used"
  familyGroups             FamilyGroup[]
  tasks               Task[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model FamilyGroup {
  id                 String         @id @default(cuid())
  accountId          String
  groupName          String
  maxMembers         Int            @default(6)
  memberCount        Int            @default(0)
  availableSlots     Int            @default(0)
  pendingInviteCount Int            @default(0)
  yearlyChangeCount  Int            @default(0)
  yearlyChangeLimit  Int            @default(6)
  status             GroupStatus    @default(ACTIVE)
  riskScore          Int            @default(0)
  lastSyncedAt       DateTime?
  account            Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  members            FamilyMember[]
  invites            FamilyInvite[]
  orders             Order[]
  tasks              Task[]
  transfersAsSource  TransferBatch[] @relation("TransferSource")
  transfersAsTarget  TransferBatch[] @relation("TransferTarget")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model FamilyMember {
  id              String       @id @default(cuid())
  familyGroupId   String
  email           String
  displayName     String?
  role            String
  status          MemberStatus @default(ACTIVE)
  googleMemberId  String?      // GAIA member ID from href="/family/member/g/{id}"
  canAutoRemove   Boolean      @default(false)
  expiresAt       DateTime?    // member-level expiry; null = never expires
  joinedAt        DateTime?
  removedAt       DateTime?
  familyGroup     FamilyGroup  @relation(fields: [familyGroupId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([familyGroupId, email])
}

model FamilyInvite {
  id            String       @id @default(cuid())
  familyGroupId String
  email         String
  status        InviteStatus @default(SENT)
  sentAt        DateTime     @default(now())
  respondedAt   DateTime?
  expiresAt     DateTime?
  familyGroup   FamilyGroup  @relation(fields: [familyGroupId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([familyGroupId, email])
}

model RedeemCode {
  id              String           @id @default(cuid())
  code            String           @unique
  product         String           @default("GOOGLE_ONE")
  codeType        RedeemCodeType   @default(JOIN_GROUP)
  usesAllowed     Int              @default(1)
  status          RedeemCodeStatus @default(UNUSED)
  expiresAt       DateTime?
  usedAt          DateTime?
  validDays       Int?             // SUBSCRIPTION: validity period in days (set at generation)
  swapLimit       Int              @default(0)  // Max swaps allowed within each window (0 = unlimited)
  swapWindowHours Int              @default(5)  // Rolling window for swap rate-limit (hours)
  order           Order?
  createdById     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status])
  @@index([codeType])
}

model Order {
  id            String       @id @default(cuid())
  orderNo       String       @unique
  orderType     OrderType    @default(JOIN)
  redeemCodeId  String?      @unique
  userEmail     String
  familyGroupId String?
  status        OrderStatus  @default(CREATED)
  resultMessage String?
  assignedAt    DateTime?
  expiresAt     DateTime?  // membership expiry (set at redeem time)
  expiredAt     DateTime?  // actual auto-removal timestamp (audit)
  swapCount     Int          @default(0)  // number of swaps performed
  lastSwapAt    DateTime?                 // timestamp of most recent swap
  redeemCode    RedeemCode?  @relation(fields: [redeemCodeId], references: [id], onDelete: SetNull)
  familyGroup   FamilyGroup? @relation(fields: [familyGroupId], references: [id], onDelete: SetNull)
  tasks         Task[]
  swapRecords   SwapRecord[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([userEmail])
  @@index([status])
  @@index([createdAt])
}

model Task {
  id                   String          @id @default(cuid())
  type                 TaskType
  orderId              String?
  familyGroupId        String?
  accountId            String?
  workerId             String?
  transferBatchId      String?
  source               String          @default("manual")
  status               TaskStatus      @default(PENDING)
  priority             Int             @default(0)
  retryCount           Int             @default(0)
  maxRetryCount        Int             @default(3)
  payload              String          @default("{}")
  lastErrorCode        String?
  lastErrorMessage     String?
  beforeScreenshotPath String?
  afterScreenshotPath  String?
  errorScreenshotPath  String?
  startedAt            DateTime?
  finishedAt           DateTime?
  order                Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  familyGroup          FamilyGroup?    @relation(fields: [familyGroupId], references: [id], onDelete: SetNull)
  account              Account?        @relation(fields: [accountId], references: [id], onDelete: SetNull)
  transferBatch        TransferBatch?  @relation(fields: [transferBatchId], references: [id], onDelete: SetNull)
  logs                 TaskLog[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([accountId, status])
  @@index([source, status])
  @@index([familyGroupId])
}

model TaskLog {
  id        String   @id @default(cuid())
  taskId    String
  level     String
  message   String
  extra     String?
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  operatorId String?
  action     String
  targetType String
  targetId   String
  detail     String?
  operator   User?    @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
}

model TransferBatch {
  id                String         @id @default(cuid())
  sourceGroupId     String
  targetGroupId     String
  phase             TransferPhase  @default(REMOVING)
  memberEmails      String         // JSON array of emails
  totalMembers      Int
  removedCount      Int            @default(0)
  removeFailedCount Int            @default(0)
  invitedCount      Int            @default(0)
  inviteFailedCount Int            @default(0)
  errorDetail       String?        // JSON array: [{email, error}]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  sourceGroup       FamilyGroup    @relation("TransferSource", fields: [sourceGroupId], references: [id])
  targetGroup       FamilyGroup    @relation("TransferTarget", fields: [targetGroupId], references: [id])
  tasks             Task[]
}

model SwapRecord {
  id        String           @id @default(cuid())
  orderId   String
  oldEmail  String
  newEmail  String
  taskId    String?
  status    SwapRecordStatus @default(PENDING)
  order     Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([orderId])
}

model SystemSchedulerConfig {
  id                          String   @id @default("default")
  enabled                     Boolean  @default(false)
  maxAccountsPerRun           Int      @default(10)
  accountCooldownMinutes      Int      @default(60)
  runWindowStart              String   @default("22:00")
  runWindowEnd                String   @default("08:00")
  staleSyncThresholdMinutes   Int      @default(1440)
  syncEnabled                 Boolean  @default(true)
  removeExpiredMembersEnabled Boolean  @default(true)
  cancelTimedOutInvitesEnabled Boolean @default(true)
  deduplicateMembersEnabled   Boolean  @default(true)
  inviteTimeoutDays           Int      @default(3)
  lastRunAt                   DateTime?
  lastRunStatus               String?
  lastRunSummary              String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

/// Phone number pool for automated Google phone verification.
/// Phones are uploaded from GFA Clients (single direction: client → server).
model PhonePool {
  id             String    @id @default(cuid())
  phoneNumber    String    @unique
  countryCode    String    @default("+1")
  smsUrl         String
  status         String    @default("available") // available / used / in_use / disabled
  usedCount      Int       @default(0)
  failureCount   Int       @default(0)
  lastUsedAt     DateTime?
  lastCode       String?
  disabledReason String?
  source         String?   // client identifier
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
}

/// Lifecycle status for agent-managed child accounts.
enum AgentAccountStatus {
  REGISTERED       // 已录入凭证
  PHONE_VERIFIED   // 已过手机验证（有refresh_token）
  IN_GROUP         // 已进组
  UPLOADED         // 已上号到CLIProxy
  REMOVED          // 已从号池删除
}

/// Child accounts managed through the Agent Service panel.
/// Separate from Account (母号). Tracks the full lifecycle:
///   REGISTERED → PHONE_VERIFIED → IN_GROUP → UPLOADED → REMOVED
model AgentAccount {
  id              String              @id @default(cuid())
  loginEmail      String              @unique
  loginPassword   String
  totpSecret      String?
  recoveryEmail   String?
  status          AgentAccountStatus  @default(REGISTERED)
  refreshToken    String?             // OAuth refresh_token (auto-captured)
  tokenObtainedAt DateTime?           // when refresh_token was last obtained
  familyGroupId   String?             // which family group this account joined
  uploadedAt      DateTime?           // when uploaded to CLIProxy
  removedAt       DateTime?           // when removed from CLIProxy
  lastTaskId      String?             // most recent automation task ID
  notes           String?
  pool            String              @default("pending")  // "pending" | "no_ban" | "ban_risk"
  banned          Boolean             @default(false)       // 已封/未封
  uploadedToPool  DateTime?           // 上号时间（移入已上号池的时间）
  motherAccountId String?             // 关联母号 Account ID
  motherGroupId   String?             // 关联家庭组 FamilyGroup ID
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([status])
  @@index([loginEmail])
  @@index([pool])
  @@index([pool, banned])
}

/// FAQ items editable from the admin console, displayed on /faq public page.
model FaqItem {
  id        String   @id @default(cuid())
  category  String                  // Category label, e.g. "加入家庭组", "反重力使用"
  question  String                  // Question title
  answer    String                  // Answer content (rich HTML)
  sortOrder Int      @default(0)    // Display order (lower = first)
  published Boolean  @default(true) // Whether visible on public page
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, sortOrder])
}

model SiteSetting {
  key       String   @id               // e.g. "contact_wechat", "contact_qrcode_url"
  value     String                     // Value (text, URL, etc.)
  updatedAt DateTime @updatedAt
}

/// 小时用量聚合:写入时按(小时 × 卡 × 上游号 × 客户 × 模型 × bucket)就地累加,
/// 行数只跟「卡×模型×小时」走、与请求次数脱钩(客户狂刷不会撑大此表)。
/// 趋势/今日/按模型/24h分布/成本 都读这张;单条明细仍读 CardTokenUsage(只留最近)。
/// hourStart = 该请求时刻向下取整到整点(UTC 起点;北京为整数时差,小时/日分桶天然对齐)。
/// 唯一键里 accountEmail/customerId 用空串("")代替 null,避免 SQLite NULL 不参与唯一约束。
model CardUsageHourly {
  id                String   @id @default(cuid())
  hourStart         DateTime                     // 整点起始(UTC 瞬时)
  accessKeyId       String
  accountEmail      String   @default("")         // 上游号稳定身份("" = 未知/legacy)
  customerId        String   @default("")         // 客户 id("" = 未绑定)
  modelKey          String
  bucket            String
  requests          Int      @default(0)
  failedRequests    Int      @default(0)          // 非 2xx 请求数(成功 = requests − failedRequests)
  inputTokens       Int      @default(0)
  outputTokens      Int      @default(0)
  cachedInputTokens Int      @default(0)
  cacheCreationTokens Int    @default(0)          // 缓存写(cache_creation);仅 claude 非零,历史行=0
  rawTotalTokens    Int      @default(0)
  totalTokens       Int      @default(0)          // 计费 token(扣缓存折扣后)
  updatedAt         DateTime @updatedAt

  @@unique([hourStart, accessKeyId, accountEmail, customerId, modelKey, bucket])
  @@index([hourStart])
  @@index([accessKeyId, hourStart])
  @@index([customerId, hourStart])
  @@index([accountEmail, hourStart])
}

/// 账号 5h/周额度水位时序:on-change 去重后由 AccountQuotaSnapshotTracker 批量写入。
/// 三家(antigravity/codex/anthropic)统一处理:读账号 modelQuotaFractions,每个 key 记一笔。
/// modelKey = 该账号 fractions 的 key(codex→"codex" / anthropic→"claude" / antigravity→真实模型名),
/// 始终有值。codex/anthropic 一个 key 带 5h+周;antigravity 每模型一行(无周窗口)。
model AccountQuotaSnapshot {
  id            String   @id @default(cuid())
  provider      String                     // antigravity | codex | anthropic
  accountId     Int
  email         String?
  modelKey      String                     // 账号 modelQuotaFractions 的 key(三家统一)
  hourlyPercent Float?                     // 5h 剩余 %(0-100)
  weeklyPercent Float?                     // 周剩余 %(antigravity 无周窗口 → null)
  hourlyResetAt DateTime?
  weeklyResetAt DateTime?
  timestamp     DateTime @default(now())

  @@index([provider, accountId, timestamp])
  @@index([timestamp])
}

/// 拼车每卡 5h/周 份额态(决定"剩余"),跨重启持久化。FairShareTracker 内存聚合 + 定时批量 upsert。
/// 恢复后按 windowStart 判过期(跨窗口边界丢弃)。
model FairShareWindow {
  provider          String
  accountId         Int
  bucket            String                   // 复合桶 product-family
  cardId            String
  windowStart       BigInt                   // epoch ms,窗口起点
  weightedUsed      Float    @default(0)      // 本段该卡已用加权 token(归并后清零的 u_i)
  attributedShare   Float    @default(0)      // T_i:本窗口累计已烧账号比例 [0,1],只增不减
  lockedDenominator Float    @default(0)      // 窗口开始锁定的分母 D = max(N, Σw)
  lastFraction      Float    @default(1)      // 低水位:窗口内单调不增的上游剩余 fraction
  isParticipant     Boolean  @default(false)  // reset 时是否在册(锁定参与卡);重启不把窗口内新绑卡误升为 participant
  updatedAt         DateTime @default(now())

  @@id([provider, accountId, bucket, cardId])
  @@index([provider, accountId, bucket])
}

// ─── Customer Account System ────────────────────────────────────────────────

enum CustomerStatus {
  ACTIVE
  DISABLED
}

enum CustomerEmailTokenPurpose {
  VERIFY_EMAIL
  RESET_PASSWORD
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PlanOrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  EXPIRED
  CANCELLED // 用户主动取消,或新建同客户订单时作废的旧未支付单(语义同 EXPIRED:可被迟到的支付回调恢复为 PAID)
}

enum PayChannel {
  ALIPAY
  WXPAY
  GRANT // 管理员手动授予(目录版):¥0、无支付,仅作订单→订阅审计链的来源标记
  ACTIVATION_CODE // 激活码兑换:不走支付,amountCents 记激活当时目录算出的等值价格,作订单→订阅审计链来源
}

enum DeviceStatus {
  ACTIVE
  REVOKED
}

enum NotificationType {
  SYSTEM
  BILLING
  TICKET
  REFERRAL
  MIGRATION
}

enum TicketStatus {
  OPEN
  ANSWERED
  CLOSED
}

enum ReferralRewardStatus {
  PENDING
  GRANTED
  REVOKED
}

/// Terminal customer — fully separate from admin User.
model Customer {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  status        CustomerStatus @default(ACTIVE)
  emailVerified Boolean        @default(false)
  displayName   String?
  tokenVersion  Int            @default(0)   // bumped on password change/reset → revokes all JWTs
  referralCode  String         @unique
  invitedById   String?
  creditCents   Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  invitedBy     Customer?              @relation("CustomerReferrals", fields: [invitedById], references: [id])
  referrals     Customer[]             @relation("CustomerReferrals")
  emailTokens   CustomerEmailToken[]
  subscriptions Subscription[]
  planOrders    PlanOrder[]
  devices       Device[]
  notifications Notification[]
  tickets       Ticket[]
  supportConversations SupportConversation[]

  @@index([invitedById])
}

/// Single-use email tokens for verification and password reset.
model CustomerEmailToken {
  id         String                    @id @default(cuid())
  customerId String
  tokenHash  String                    @unique
  purpose    CustomerEmailTokenPurpose
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime                  @default(now())

  customer   Customer                  @relation(fields: [customerId], references: [id])

  @@index([customerId])
}

/// Active / past subscription; its id doubles as shadow access-key record id and fair-share cardId.
/// For migrated cards the id is set to the old card's id on create.
model Subscription {
  id                  String             @id @default(cuid())
  customerId          String
  status              SubscriptionStatus @default(ACTIVE)
  startsAt            DateTime           @default(now())
  expiresAt           DateTime?          // nullable: migrated never-used card has no expiry until first use
  activatedFromOrderId String?           // PlanOrder.id that created/last extended this sub — exact order→sub link for reconcile + refund
  activatedFromActivationCodeId String?  // set ONLY for activation-code subs: the ActivationCode.id that opened this sub (audit/provenance)
  migratedFromKey     String?            // set ONLY for card-migrated subs: the original card key (provenance). Catalog purchases leave it null.
  // 去影子:限额配置单一真相源(JSON 字符串;SQLite 无 Json,与 bucketLimits 等一致)。
  // 购买时快照展开的实际值(含显式 line),运行时直读它喂限额引擎、判号池/绑定。见 spec §4.2 / §6。
  config              String?
  catalogVersion      Int?               // 买时的 PlanCatalog 版本(溯源 / 价格锁定)
  // Purchase-time snapshots: the runtime mirror columns lease-service still reads.
  productEntitlements String
  bucketLimits        String?
  bindings            String?            // JSON product→accountId mirror
  levels              String?
  weight              Int                @default(1)
  priority            Int                @default(0)  // Account-internal failover order: lower = used first
  deviceLimit         Int                @default(1)
  weeklyTokenLimit    Int?
  windowMs            Int                @default(18000000)
  backingKeyValue     String             @unique  // opaque key value written into access-keys.json
  // 限流窗口快照(JSON 字符串):{ windowStartedAt, weeklyWindowStartedAt, tokenUsageEvents, weeklyTokenUsageEvents }。
  // 由 token-server 定时 + 关机持久化;重启时直接恢复 5h/周窗口(精准,不再从 CardTokenUsage 回放)。
  windowState         String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  customer  Customer  @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([activatedFromOrderId])
}

/// Versioned plan catalog: global pricing / level / usage rules, published to clients.
/// `config` is a JSON string (sqlite has no Json type) holding
/// products/levels/usageTiers/pricing/durationDays/windowMs — see spec §4.1.
model PlanCatalog {
  id          String    @id @default(cuid())
  version     Int       @unique
  status      String    @default("DRAFT") // DRAFT | PUBLISHED | ARCHIVED
  config      String
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([status])
}

/// Plan purchase order (distinct from the existing family-group Order).
/// Catalog-only: every order carries catalogVersion/selection/config —
/// config is the computePurchase snapshot written into Subscription on activation. See spec §8.
model PlanOrder {
  id             String         @id @default(cuid())
  customerId     String
  subscriptionId String?        // filled on activation
  amountCents    Int
  payChannel     PayChannel
  outTradeNo     String         @unique  // idempotency anchor
  epayTradeNo    String?
  status         PlanOrderStatus @default(PENDING)
  notifyRaw      String?
  paidAt         DateTime?
  referrerId     String?        // Customer id of inviter at purchase time
  // Catalog purchase snapshot:
  catalogVersion Int?           // PUBLISHED PlanCatalog version priced against (price lock / 溯源)
  selection      String?        // JSON of the customer's selection (audit / re-pricing)
  config         String?        // JSON config from computePurchase → written into Subscription.config on activation
  expiresAt      DateTime       // pending-payment TTL
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  customer  Customer  @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([status])
}

enum ActivationCodeStatus {
  UNUSED // 已生成,未激活
  ACTIVATED // 已被用户激活并开通订阅
  DISABLED // 管理员停用
}

/// 激活码:生成时只是「码 + selection 模板」,不绑账号、不占座位、永久有效到激活。
/// 用户在 web account 后台兑换时,按 selection 对「当前 PUBLISHED 目录」computePurchase 现算 config,
/// 造一笔 ACTIVATION_CODE 订单 + 开通一条新订阅(座位在那时才分配)。见激活码改造方案。
model ActivationCode {
  id                    String               @id @default(cuid())
  code                  String               @unique // 展示给用户的激活码串
  // 激活时开通什么订阅的模板(PoolSelection | BindSelection 的 JSON);激活时对最新目录算价/配置。
  selection             String
  status                ActivationCodeStatus @default(UNUSED)
  // 激活追踪:
  activatedAt           DateTime? // 用户激活时间
  activatedByCustomerId String? // 激活的客户 id
  subscriptionId        String? // 激活后开通的 Subscription.id
  // 管理:
  name                  String? // 备注名
  batchId               String? // 批量生成分组(筛选/导出/整批停用)
  createdById           String? // 生成此码的操作员 id
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([status])
  @@index([batchId])
  @@index([activatedByCustomerId])
}

/// Customer device (supports multi-device enforcement and session revocation).
model Device {
  id          String       @id @default(cuid())
  customerId  String
  deviceId    String       // client-generated stable id
  name        String?
  platform    String?
  status      DeviceStatus @default(ACTIVE)
  lastSeenAt  DateTime?
  lastIp      String?
  sessionJti  String?      // current session token id; mismatch = revoked
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  customer    Customer     @relation(fields: [customerId], references: [id])

  @@unique([customerId, deviceId])
  @@index([customerId])
}

/// In-app notification for a customer.
model Notification {
  id         String           @id @default(cuid())
  customerId String
  type       NotificationType @default(SYSTEM)
  title      String
  body       String?
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  customer   Customer         @relation(fields: [customerId], references: [id])

  @@index([customerId, createdAt])
}

/// Support ticket opened by a customer.
model Ticket {
  id         String       @id @default(cuid())
  customerId String
  subject    String
  status     TicketStatus @default(OPEN)
  closedBy   String?                      // 关闭来源:"CUSTOMER"(用户自助关) | "ADMIN"(客服关);仅 status=CLOSED 时有意义
  urgent     Boolean      @default(false) // 加急处理:客户或管理员可置;关闭工单时自动清
  urgentAt   DateTime?                    // 置加急的时间(取消/关闭时归 null)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  customer   Customer       @relation(fields: [customerId], references: [id])
  messages   TicketMessage[]

  @@index([customerId])
}

/// Individual message within a support ticket.
model TicketMessage {
  id         String   @id @default(cuid())
  ticketId   String
  authorType String   // "CUSTOMER" | "ADMIN"
  authorId   String?
  body       String
  createdAt  DateTime @default(now())

  ticket     Ticket   @relation(fields: [ticketId], references: [id])

  @@index([ticketId])
}

/// AI 客服对话会话(客户端悬浮气泡)。一个客户可有多段对话。
model SupportConversation {
  id         String           @id @default(cuid())
  customerId String
  status     String           @default("OPEN") // 会话生命周期:OPEN(进行中) | CLOSED(已结束,空闲>30min)
  ticketId   String?                           // 转人工建的工单 id;非空=已转人工(与 status 正交)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  customer   Customer         @relation(fields: [customerId], references: [id])
  messages   SupportMessage[]

  @@index([customerId, updatedAt])
}

/// 客服对话内的单条消息。
model SupportMessage {
  id             String              @id @default(cuid())
  conversationId String
  role           String              // USER | ASSISTANT | TOOL
  content        String
  name           String?             // TOOL 消息:工具名(审计用)
  toolCalls      String?             // assistant 发起的 tool_calls(JSON 字符串)
  createdAt      DateTime            @default(now())

  conversation   SupportConversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId, createdAt])
}

/// 由工单提炼的客服知识条目(知识飞轮)。bot 检索已发布条目作答。
model KnowledgeEntry {
  id             String   @id @default(cuid())
  question       String                       // 归一化问题
  answer         String                       // 通用解法
  category       String?
  status         String   @default("DRAFT")   // DRAFT | PUBLISHED | ARCHIVED | MERGE_SUGGESTED
  mergeTargetId  String?                      // MERGE_SUGGESTED 时指向要更新的现有条目
  sourceTicketId String?                      // 来源工单 id
  usageCount     Int      @default(0)         // 被 bot 引用次数
  createdBy      String   @default("AI")      // "AI" | <adminId>
  embedding      String?                      // 预留:Phase2 存 float[] JSON
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
}

/// Referral reward record — one per qualifying order, replay-safe.
model ReferralReward {
  id           String               @id @default(cuid())
  referrerId   String               // Customer id being rewarded
  inviteeId    String
  planOrderId  String               @unique  // one reward per order
  amountCents  Int
  status       ReferralRewardStatus @default(GRANTED)
  createdAt    DateTime             @default(now())

  @@index([referrerId])
}
